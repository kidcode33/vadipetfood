# VadiPetFood — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# .env dosyası asla Git'e commit edilmemeli (.gitignore'da tanımlı).

# ── WhatsApp ──────────────────────────────────────────────────────
# Uluslararası formatta, başında + olmadan
# Örnek: 905551234567
VITE_WHATSAPP_NUMBER=905555555555

# ── Anthropic API ─────────────────────────────────────────────────
# Bu değişken Netlify Functions (sunucu tarafı) tarafından kullanılır.
# Tarayıcıya açılmaz — VITE_ prefix'i OLMAMALI.
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
